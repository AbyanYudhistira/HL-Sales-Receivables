{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "AUTH_SECRET", "AUTH_TRUST_HOST"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "AUTH_SECRET", "AUTH_TRUST_HOST"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
