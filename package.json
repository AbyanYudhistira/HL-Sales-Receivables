{
  "name": "hl-sales",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @hl/database exec prisma migrate dev",
    "db:seed": "pnpm --filter @hl/database exec prisma db seed",
    "db:studio": "pnpm --filter @hl/database exec prisma studio",
    "db:generate": "pnpm --filter @hl/database exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.13.1"
}
