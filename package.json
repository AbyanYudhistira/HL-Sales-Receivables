{
  "name": "hl-sales",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "postinstall": "pnpm db:generate",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @hl/database run db:migrate",
    "db:migrate:deploy": "pnpm --filter @hl/database run db:migrate:deploy",
    "db:seed": "pnpm --filter @hl/database run db:seed",
    "db:studio": "pnpm --filter @hl/database run db:studio",
    "db:generate": "pnpm --filter @hl/database run db:generate"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
